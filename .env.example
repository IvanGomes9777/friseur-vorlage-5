# Kontaktformular-Versand (optional – ohne diese Werte läuft ein Dev-Fallback)
# In Vercel: Settings → Environment Variables eintragen.

# API-Key von https://resend.com
RESEND_API_KEY=

# Empfänger der Kontaktanfragen
CONTACT_TO=info@salon-muster.de

# Verifizierter Absender (Domain muss in Resend verifiziert sein)
CONTACT_FROM=Salon Muster <kontakt@salon-muster.de>
